# Ekip Arkadaşım: Bu dosyayı kopyala, adını .env yap ve kendi şifrelerini/bilgilerini doldur.

# Docker İçin PostgreSQL Ayarları
POSTGRES_USER=endux_admin
POSTGRES_PASSWORD=q1w2e3
POSTGRES_DB=endux_db

# Prisma ve Node.js İçin Veritabanı Bağlantı Linki
# Format: postgresql://KULLANICI:ŞİFRE@localhost:5433/VERİTABANI_ADI?schema=public
DATABASE_URL="postgresql://kendi_kullanici_adini_yaz:kendi_sifreni_yaz@localhost:5433/endux_db?schema=public"
DIRECT_URL="postgresql://kendi_kullanici_adini_yaz:kendi_sifreni_yaz@localhost:5433/endux_db?schema=public"
AI_SERVICE_URL=http://endux_ai:8000

# Sunucu Ayarları
PORT=3000
JWT_SECRET=endux_jwt
JWT_EXPIRES_IN=7d
