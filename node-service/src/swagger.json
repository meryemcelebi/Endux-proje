{
  "openapi": "3.0.0",
  "info": {
    "title": "Maintify ERP Entegrasyon API Dokümantasyonu",
    "version": "1.0.0",
    "description": "Maintify TPM sisteminin fabrikadaki harici ERP yazılımları  ile haberleşmesini sağlayan standart API kapıları."
  },
  "servers": [
    {
      "url": "http://localhost:3001/api/v1/integration",
      "description": "Yerel Geliştirme Sunucusu"
    }
  ],
  "components": {
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "X-ERP-Secret-Key",
        "description": "ERP sistemine özel tanımlanmış gizli entegrasyon anahtarı."
      }
    }
  },
  "security": [
    {
      "ApiKeyAuth": []
    }
  ],
  "paths": {
    "/erp/inventory-sync": {
      "post": {
        "summary": "Stok ve Yedek Parça Senkronizasyonu",
        "description": "ERP sisteminde depoya yeni yedek parça girdiğinde veya stok güncellendiğinde Maintify veritabanını senkronize eder.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "part_code": { "type": "string", "example": "FLT-001" },
                  "quantity": { "type": "integer", "example": 50 },
                  "update_type": { "type": "string", "example": "SET" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Stok başarıyla güncellendi." },
          "401": { "description": "Geçersiz API Anahtarı." }
        }
      }
    },
    "/erp/machine-sync": {
      "post": {
        "summary": "Yeni Makine Entegrasyonu",
        "description": "Fabrikaya yeni bir makine satın alınıp ERP'ye kaydedildiğinde, makineyi otomatik olarak Maintify sistemine aktarır.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "machine_code": { "type": "string", "example": "CNC-402" },
                  "machine_name": { "type": "string", "example": "CNC Dik İşlem Merkezi - Ünite 40" },
                  "hourly_downtime_cost": { "type": "number", "example": 150.00 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Makine başarıyla sisteme eklendi." },
          "401": { "description": "Yetkisiz Erişim." }
        }
      }
    }
  }
}