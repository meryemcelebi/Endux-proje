import pandas as pd
import numpy as np
import random
import os

print("🤖 KB-V2 Gelişmiş Sentetik Veri Üreticisi Başlıyor...")

KAYIT_SAYISI = 10000

MAKINE_TURLERI = [
    "Plastik ve Enjeksiyon", "Talaşlı İmalat", "Yardımcı Tesis",
    "Kalite Kontrol", "Otomasyon ve Robotik", "Sac ve Şekillendirme",
    "Döküm ve Isıl İşlem", "Paketleme ve Lojistik"
]

# Makinelere özel tüm sensör sütunlarının listesi (XGBoost'un göreceği o geniş matris için)
OZEL_SUTUNLAR = [
    "hidrolik_yag_durumu", "rezistans_kokusu", "bor_yag_rengi", "spindle_titresim",
    "alt_su_tahliye", "mercek_temizligi", "kaynak_torcu", "kablo_sarmali",
    "isik_bariyeri", "sizma_kontrolu", "termal_gozlem", "sogutma_suyu",
    "teflon_kontrolu", "fotosel_algilama"
]

veri_listesi = []

for _ in range(KAYIT_SAYISI):
    # 1. TEMEL DEĞERLER VE TEORİK YIPRANMA (Meryem'in Mantığı)
    makine = random.choice(MAKINE_TURLERI)
    bakim_periyodu = random.choice([4000, 5000, 6000, 8000]) 
    calisma_saati = random.randint(50, int(bakim_periyodu * 1.1)) # Bazen bakımı %10 geçsin ki AI arızayı öğrensin
    
    # Sadece saate dayalı, hiçbir dış etkenin olmadığı "Kağıt Üstündeki" yıpranma
    teorik_yipranma = (calisma_saati / bakim_periyodu) * 100.0
    
    # Yaşlanma Katsayısı: Makine eskiyse hata verme ihtimali artar (Senin orijinal zeki mantığın)
    y_katsayi = calisma_saati / bakim_periyodu 

    # 2. TEMEL SENSÖR VERİLERİ (0: Normal, 1: Uyarı, 2: Kritik)
    sicaklik = 0; titresim = 0; yag = 0; genel = 0; sizinti = 0; kablo = 0
    
    if random.random() < y_katsayi:
        sicaklik = random.choices([0, 1, 2], weights=[0.5, 0.3, 0.2])[0]
        titresim = random.choices([0, 1, 2], weights=[0.6, 0.3, 0.1])[0]
        yag =      random.choices([0, 1, 2], weights=[0.7, 0.2, 0.1])[0]
        sizinti =  random.choices([0, 1, 2], weights=[0.8, 0.15, 0.05])[0]
        kablo =    random.choices([0, 1, 2], weights=[0.8, 0.15, 0.05])[0]
        genel = max(sicaklik, titresim, sizinti) # Genel durum en kötü sensöre göre şekillenir

    # 3. ÖZEL SENSÖR VERİLERİ (Seyrek Matris - Sparse Matrix Mantığı)
    # Önce tüm özel sensörleri 0 (Normal/Yok) kabul ediyoruz.
    ozel_veri_dict = {sutun: 0 for sutun in OZEL_SUTUNLAR}
    
    # Sonra sadece seçilen makineye ait olan sensörleri, makinenin yaşına göre bozuyoruz
    if random.random() < y_katsayi:
        if makine == "Plastik ve Enjeksiyon":
            ozel_veri_dict["hidrolik_yag_durumu"] = random.choices([0, 1, 2], weights=[0.6, 0.3, 0.1])[0]
            ozel_veri_dict["rezistans_kokusu"] = random.choices([0, 1, 2], weights=[0.7, 0.2, 0.1])[0]
        elif makine == "Talaşlı İmalat":
            ozel_veri_dict["bor_yag_rengi"] = random.choices([0, 1, 2], weights=[0.5, 0.3, 0.2])[0]
            ozel_veri_dict["spindle_titresim"] = random.choices([0, 1, 2], weights=[0.6, 0.3, 0.1])[0]
        elif makine == "Yardımcı Tesis":
            ozel_veri_dict["alt_su_tahliye"] = random.choices([0, 1, 2], weights=[0.7, 0.2, 0.1])[0]
        # (AI diğer makineler için de pattern bulsun diye 0,1,2 dağıtıyoruz)
        elif makine == "Döküm ve Isıl İşlem":
            ozel_veri_dict["termal_gozlem"] = random.choices([0, 1, 2], weights=[0.4, 0.4, 0.2])[0]
            ozel_veri_dict["sogutma_suyu"] = random.choices([0, 1, 2], weights=[0.5, 0.3, 0.2])[0]

    # 4. YIPRANMA CEZALARI (Regresyon Hedefi İçin Fiziksel Kurgu)
    # Yapay zekanın "ezberlemeden" çözmeye çalışacağı asıl matematik burası!
    ceza_puani = 0.0
    
    # Kritik hatalar büyük ceza verir
    if sicaklik == 2: ceza_puani += random.uniform(15.0, 25.0)  
    if titresim == 2: ceza_puani += random.uniform(10.0, 20.0)
    if yag == 2: ceza_puani += random.uniform(20.0, 30.0)       # Yağsızlık motoru mahveder
    
    # Uyarı hataları küçük ceza verir
    if sicaklik == 1: ceza_puani += random.uniform(2.0, 5.0)
    if titresim == 1: ceza_puani += random.uniform(2.0, 6.0)
    
    # Makineye özel hataların cezaları
    if ozel_veri_dict.get("rezistans_kokusu", 0) == 2: ceza_puani += random.uniform(10.0, 15.0)
    if ozel_veri_dict.get("sogutma_suyu", 0) == 2: ceza_puani += random.uniform(25.0, 35.0)

    # NİHAİ GERÇEK YIPRANMA (Teorik + Cezalar)
    gercek_yipranma = teorik_yipranma + ceza_puani
    if gercek_yipranma > 100.0: gercek_yipranma = 100.0 # %100'ü geçemez
    if gercek_yipranma < 0.0: gercek_yipranma = 0.0

    # 5. ARIZA ETİKETLEME (Sınıflandırma Hedefi)
    ariza_tipi = "Yok"
    
    if sicaklik == 2 and (yag >= 1 or ozel_veri_dict.get("sogutma_suyu", 0) >= 1):
        ariza_tipi = "HDF" # Isı Dağılım Hatası
    elif titresim == 2 or ozel_veri_dict.get("spindle_titresim", 0) == 2:
        ariza_tipi = "TWF" # Aşınma/Kırılma Hatası
    elif sizinti == 2 or kablo == 2:
        ariza_tipi = "OSF" # Operasyonel Hata
    elif gercek_yipranma > 95.0 and ariza_tipi == "Yok":
        # Yıpranma tavan yapmış ama spesifik sensör yakalayamamışsa bu genel güç hatasıdır
        ariza_tipi = "PWF" 

    # 6. SÖZLÜĞÜ OLUŞTUR VE LİSTEYE EKLE
    satir_verisi = {
        "makine_turu": makine,
        "calisma_saati": calisma_saati,
        "genel_bakim_periyodu_saat": bakim_periyodu,
        "sicaklik_durumu": sicaklik,
        "titresim_hissi": titresim,
        "yag_seviyesi": yag,
        "genel_durum": genel,
        "sizinti_durumu": sizinti,
        "kablo_hasar_durumu": kablo,
    }
    
    # Özel sütunları da satıra ekle (Geniş matris tamamlanıyor)
    satir_verisi.update(ozel_veri_dict)
    
    # HEDEF (TARGET) KOLONLAR
    satir_verisi["Hedef_Ariza_Tipi"] = ariza_tipi
    satir_verisi["Hedef_Gercek_Yipranma"] = round(gercek_yipranma, 2)

    veri_listesi.append(satir_verisi)

# 7. EXCEL/CSV OLARAK KAYDET
klasor_yolu = os.path.dirname(os.path.abspath(__file__))
data_klasoru = os.path.join(klasor_yolu, "data")
os.makedirs(data_klasoru, exist_ok=True) # Data klasörü yoksa oluştur

csv_dosyasi = os.path.join(data_klasoru, "kb_v2_egitim_verisi_v2.csv")

df = pd.DataFrame(veri_listesi)
df.to_csv(csv_dosyasi, index=False)

print(f"✅ Başarılı! 10.000 satırlık, özel sensörleri ve gerçek yıpranma yüzdelerini içeren veri seti yaratıldı.")
print(f"📂 Dosya Yolu: {csv_dosyasi}")