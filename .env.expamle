# Ekip Arkadaşım: Bu dosyayı kopyala, adını .env yap ve kendi şifrelerini doldur.
POSTGRES_USER=kendi_kullanici_adini_yaz
POSTGRES_PASSWORD=kendi_sifreni_yaz
POSTGRES_DB=endux_db

DATABASE_URL="postgresql://kullanici_adi:sifre@localhost:5432/endux_db?schema=public"

PORT=3000
JWT_SECRET=kendi_jwt_sirrini_belirle