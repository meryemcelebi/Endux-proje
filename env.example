# Ekip Arkadaşım: Bu dosyayı kopyala, adını .env yap ve kendi şifrelerini/bilgilerini doldur.

# Docker İçin PostgreSQL Ayarları
POSTGRES_USER=kendi_kullanici_adini_yaz
POSTGRES_PASSWORD=kendi_sifreni_yaz
POSTGRES_DB=endux_db

# Prisma ve Node.js İçin Veritabanı Bağlantı Linki
# Format: postgresql://KULLANICI:ŞİFRE@localhost:5432/VERİTABANI_ADI?schema=public
DATABASE_URL="postgresql://kendi_kullanici_adini_yaz:kendi_sifreni_yaz@localhost:5432/endux_db?schema=public"

# Sunucu Ayarları
PORT=3000
JWT_SECRET=kendi_jwt_sirrini_belirle
JWT_EXPIRES_IN=7d